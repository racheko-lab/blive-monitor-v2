# 本地开发用环境变量模板。
#
# 用法：复制本文件为 .dev.vars 并填入真实值（.dev.vars 已被 gitignore，切勿入库）：
#   cp .dev.vars.example .dev.vars
#
# .dev.vars 仅在 `wrangler dev` 本地联调时生效；生产环境请用 Secret：
#   wrangler secret put GH_TOKEN

# Cloudflare 细粒度 PAT：仅需该仓库 contents:write 权限
GH_TOKEN=<你的GitHub细粒度PAT>

# 与 wrangler.toml 中 [vars].PASSPHRASE 保持一致
PASSPHRASE=change-me-shared-passphrase
